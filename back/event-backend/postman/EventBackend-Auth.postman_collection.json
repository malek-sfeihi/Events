{
  "info": {
    "_postman_id": "e5c3b45f-b88f-4b6f-a2f1-2f29ad3df8b5",
    "name": "Event Backend - Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Auth flow tests for event-backend (Spring Boot)."
  },
  "item": [
    {
      "name": "Health - Public",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"Health status is UP\", function () {",
              "    pm.expect(body.status).to.eql(\"UP\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Malek User\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"role\": \"ORGANISATEUR\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Register returns 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"Register returns token and role\", function () {",
              "    pm.expect(body).to.have.property(\"token\");",
              "    pm.expect(body).to.have.property(\"role\");",
              "});",
              "",
              "if (body.token) {",
              "    pm.collectionVariables.set(\"jwtToken\", body.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Login returns 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"Login returns token\", function () {",
              "    pm.expect(body).to.have.property(\"token\");",
              "});",
              "",
              "if (body.token) {",
              "    pm.collectionVariables.set(\"jwtToken\", body.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Me - Protected",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Protected endpoint returns 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"Protected message is returned\", function () {",
              "    pm.expect(body.message).to.eql(\"JWT valide\");",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwtToken",
      "value": ""
    }
  ]
}
